{
  "name": "lexcommons-multimedia-mentor",
  "version": "1.0.0",
  "description": "Oral advocacy analysis app with real-time pitch/decibel graphs, video annotation, and professor feedback",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux"
  },
  "build": {
    "appId": "org.lexcommons.multimedia-mentor",
    "productName": "LexCommons Multimedia Mentor",
    "publish": {
      "provider": "github",
      "owner": "ProfJAJONES",
      "repo": "LexCommonsMultiMediaMentor"
    },
    "directories": {
      "buildResources": "resources",
      "output": "dist-app"
    },
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "extraResources": [
      {
        "from": "resources/BlackHole2ch.pkg",
        "to": "BlackHole2ch.pkg"
      }
    ],
    "afterPack": "./scripts/afterPack.js",
    "mac": {
      "category": "public.app-category.education",
      "identity": "820F91719449D2D5A93C650B759258E6CC783134",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "sign": "./scripts/sign.js",
      "notarize": true,
      "extendInfo": {
        "NSCameraUsageDescription": "LexCommons Multimedia Mentor uses your camera for webcam practice sessions.",
        "NSMicrophoneUsageDescription": "LexCommons Multimedia Mentor uses your microphone for real-time pitch and volume analysis."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "keywords": [],
  "author": "Joshua",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@xenova/transformers": "^2.17.2",
    "docx": "^9.6.1",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "konva": "^10.2.5",
    "pitchfinder": "^2.3.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-konva": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
