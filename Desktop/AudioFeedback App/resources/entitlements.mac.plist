<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- V8 JIT: required for Electron / Node.js to run at all -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- V8 snapshot / WASM: writing to executable memory pages -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Native addons (onnxruntime, audio-speaker, sharp) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Network: Claude/OpenAI/Gemini API calls -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Hardware: webcam and microphone -->
  <key>com.apple.security.device.camera</key>
  <true/>
  <key>com.apple.security.device.microphone</key>
  <true/>
  <!-- File access: open/save video files -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
